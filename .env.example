# LLM Provider: "ollama" or "openai"
LLM_PROVIDER=openai

# OpenAI settings (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

# The chat action router is always enabled and uses LLM_PROVIDER plus its model
# by default. These optional overrides can point routing at a different model.
# ROUTER_LLM_PROVIDER=openai
# ROUTER_OPENAI_MODEL=gpt-4o-mini
# ROUTER_OPENROUTER_MODEL=
# ROUTER_OLLAMA_MODEL=
# ROUTER_OLLAMA_BASE_URL=
# ROUTER_LMSTUDIO_MODEL=
# ROUTER_TEMPERATURE=0.0

# Ollama settings (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_DIMENSIONS=1536

# Tavily Search API Key
TAVILY_API_KEY=your_key_here

# arXiv MCP (bundled with backend deps; no separate service required)
# The backend launches arxiv-mcp-server automatically and startup fails if it is unavailable.
# ARXIV_MCP_STORAGE_PATH=~/.arxiv-mcp-server/papers
# ARXIV_MCP_COMMAND=

# Asset price provider
ASSET_PRICE_PROVIDER=alphavantage_mcp
ALPHA_VANTAGE_API_KEY=your_key_here
ALPHA_VANTAGE_MCP_TOOL_REFRESH_SECONDS=3600
# Optional full remote MCP URL override
# ALPHA_VANTAGE_MCP_URL=https://mcp.alphavantage.co/mcp?apikey=your_key_here

# Neo4j graph store (GraphRAG)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j
GRAPH_RAG_TOP_K=8
GRAPH_RAG_MAX_HOPS=2

# API server settings
API_HOST=0.0.0.0
API_PORT=8010
# Comma-separated list of allowed CORS origins (defaults to localhost:5173 if unset)
# CORS_ORIGINS=https://app.example.com,https://staging.example.com

# Number of search results to retrieve
MAX_SEARCH_RESULTS=5

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=cortex
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_REDACTION_MODE=redacted_default
LANGSMITH_SAMPLING_RATE=1.0

# Supabase auth + persistence
SUPABASE_URL=
# Backend: sb_secret_... from Dashboard → Settings → API Keys (not legacy service_role)
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated

# RAG orchestration
RAG_STORAGE_BUCKET=rag-resources
RAG_SIGNED_URL_TTL_SECONDS=600
RAG_CHAT_MAX_HISTORY_MESSAGES=20
RAG_CHAT_CONDITIONAL_TOOLS=true
RAG_SUGGESTIONS_DEFERRED=false
RAG_CHAT_TITLE_LLM_BACKGROUND=true
RAG_PERF_HEADERS=false
# Benchmark: BENCHMARK_USER_ID, BENCHMARK_AGENT_ID, BENCHMARK_BEARER_TOKEN (live API)

# Inngest (INNGEST_DEV=1 for local dev; set INNGEST_EVENT_KEY in production)
INNGEST_DEV=1
INNGEST_EVENT_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:5173

# Redis cache (optional — leave unset to disable caching)
# REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_TTL_DB_LIST_SECONDS=30

# Sentry error tracking (optional — leave unset to disable)
# SENTRY_DSN=
